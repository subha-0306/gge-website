# ── Server ──
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ──
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gge_leads?retryWrites=true&w=majority

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h

# ── Admin Seed ──
ADMIN_EMAIL=admin@ggenterprises.com
ADMIN_PASSWORD=GGE@Admin2026
ADMIN_NAME=GGE Admin

# ── Email (SMTP — Gmail App Password) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ggenterprises.fin@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ── Notification Recipients (comma-separated) ──
NOTIFY_EMAILS=ggenterprises.fin@gmail.com,tridentcapitalservices@gmail.com

# ── Frontend URL (for CORS) ──
FRONTEND_URL=http://localhost:5173
